# Used by Prisma, `npm run dev`, and `npm run db:load_data` (see `config/game.json`).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"
PORT=5001

# Optional: path to game config (default: repo `config/game.json` when resolving from `backend/dist` or `backend/src`).
# GAME_CONFIG_PATH="../config/game.json"
